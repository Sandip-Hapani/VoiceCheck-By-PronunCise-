# Root .env for `docker compose`. Copy to `.env` and fill in your Firebase web
# app config (Firebase Console -> Project settings -> Your apps -> SDK config).
# These are baked into the frontend build. (Firebase web keys are not secret.)
#
#   cp .env.example .env
#   docker compose up --build

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional: only needed if you want to test the hosted-mode backends
# (Groq / Cloudflare R2) locally via `docker compose up`. Leave empty to
# keep using Ollama + local disk, as usual.
GROQ_API_KEY=
GROQ_MODEL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=
