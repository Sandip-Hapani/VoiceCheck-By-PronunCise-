# Copy to .env and adjust as needed. All values have sensible defaults.

# --- Whisper ---
WHISPER_MODEL=base

# --- LLM (Ollama) ---
# Falls back to deterministic mock feedback if Ollama is unreachable.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
LLM_TIMEOUT_SECONDS=120

# --- Firebase ---
# Absolute or relative path to your service-account JSON.
# Leave empty to use Application Default Credentials (e.g. on Cloud Run).
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
FIRESTORE_COLLECTION=submissions

# --- Auth ---
# Set to false to skip Firebase ID-token verification during local smoke tests.
VERIFY_AUTH=true

# --- Storage ---
AUDIO_STORE_DIR=audio_store
PUBLIC_BASE_URL=http://localhost:8000

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173
