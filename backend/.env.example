# Copy to .env and adjust as needed. All values have sensible defaults.

# --- Whisper ---
WHISPER_MODEL=base

# --- LLM ---
# Local dev: Ollama, no key needed. Falls back to deterministic mock feedback
# if neither Ollama nor Groq is reachable.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
LLM_TIMEOUT_SECONDS=120

# Hosted/production: set GROQ_API_KEY to use Groq's free-tier API instead of
# Ollama (no local GPU needed). Get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# --- Firebase ---
# Absolute or relative path to your service-account JSON.
GOOGLE_APPLICATION_CREDENTIALS=./serviceAccount.json
# Alternative for hosts with no file mounts (e.g. a Secret Manager value
# mounted as an env var): paste the full service-account JSON contents here
# instead. Leave both empty to use Application Default Credentials — e.g. on
# Cloud Run, grant the runtime service account the "Cloud Datastore User" role.
GOOGLE_APPLICATION_CREDENTIALS_JSON=
FIRESTORE_COLLECTION=submissions

# Firebase Storage bucket for audio. Find it in the Firebase console under
# Storage (looks like "my-project.appspot.com" or "my-project.firebasestorage.app").
# When set, audio is uploaded here and played from a Firebase URL. Leave empty
# to fall through to Cloudflare R2 (below), then local disk.
FIREBASE_STORAGE_BUCKET=

# --- Cloudflare R2 (optional, free 10GB) ---
# S3-compatible persistent audio storage — use this on hosts with ephemeral
# disk (e.g. Cloud Run) instead of paying for Firebase Storage.
# Dashboard: R2 -> Manage R2 API Tokens. Leave all empty to store audio
# locally instead (fine for Docker/local dev, NOT fine for Cloud Run).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_BASE_URL=

# --- Auth ---
# Set to false to skip Firebase ID-token verification during local smoke tests.
VERIFY_AUTH=true

# --- Storage ---
AUDIO_STORE_DIR=audio_store
PUBLIC_BASE_URL=http://localhost:8000

# --- CORS (comma-separated) ---
CORS_ORIGINS=http://localhost:5173
